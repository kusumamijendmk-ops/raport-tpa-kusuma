rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && (request.auth.token.email == "kusumamijen.dmk@gmail.com" || request.auth.token.email == "admin@paud.local" || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")); }
    function isGuru() { return isSignedIn() && (isAdmin() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "guru")); }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation Helpers
    function isValidUser(data) { return data.uid is string && data.email is string && data.role in ['admin', 'guru'] && data.nama is string; }
    function isValidKelas(data) { return data.id is string && data.namaKelas is string && data.waliKelas is string; }
    function isValidSiswa(data) { return data.id is string && data.namaSiswa is string && data.idKelas is string; }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin()) && isValidUser(incoming());
    }

    match /kelas/{kelasId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidKelas(incoming());
    }

    match /tujuanPembelajaran/{tpId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /kategoriIntrakurikuler/{katId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /subdimensiKokurikuler/{subId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /nilaiIntrakurikuler/{nilaiId} {
      allow read: if isSignedIn();
      allow write: if isGuru();
    }

    match /nilaiKokurikuler/{nilaiId} {
      allow read: if isSignedIn();
      allow write: if isGuru();
    }

    match /catatanAnak/{catatanId} {
      allow read: if isSignedIn();
      allow write: if isGuru();
    }

    match /kehadiran/{kehadiranId} {
      allow read: if isSignedIn();
      allow write: if isGuru();
    }

    match /labelP5/{labelId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /dataSekolah/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /siswa/{siswaId} {
      allow read: if isSignedIn();
      allow write: if isGuru() && isValidSiswa(incoming());
    }

    match /test/{docId} {
      allow read: if true;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
