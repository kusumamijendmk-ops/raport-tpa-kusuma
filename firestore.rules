rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
         request.auth.token.email == "kusumamijen.dmk@gmail.com" ||
         request.auth.token.email == "admin@paud.local" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      ); 
    }
    function isGuru() { return isSignedIn() && (isAdmin() || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "guru")); }
    
    // Users
    match /users/{userId} {
      allow read, write: if true;
    }

    // Academic Data (Legacy Flat Collections, kept for backward compatibility and fallback)
    match /kelas/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /siswa/{docId} {
      allow read: if isSignedIn();
      allow write: if isGuru();
    }
    match /tujuanPembelajaran/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /kategoriIntrakurikuler/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /subdimensiKokurikuler/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /nilaiIntrakurikuler/{docId} {
      allow read: if isSignedIn();
      allow write: if isGuru();
    }
    match /nilaiKokurikuler/{docId} {
      allow read: if isSignedIn();
      allow write: if isGuru();
    }
    match /catatanAnak/{docId} {
      allow read: if isSignedIn();
      allow write: if isGuru();
    }
    match /kehadiran/{docId} {
      allow read: if isSignedIn();
      allow write: if isGuru();
    }
    match /labelP5/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /dataSekolah/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Year-Scoped and Semester-Scoped Academic Data
    match /tahun_pelajaran/{year} {
      match /kelas/{docId} {
        allow read, list: if isSignedIn();
        allow write, create, update, delete: if isAdmin();
      }
      match /siswa/{docId} {
        allow read, list: if isSignedIn();
        allow write, create, update, delete: if isGuru();
      }
      match /tujuanPembelajaran/{docId} {
        allow read, list: if isSignedIn();
        allow write, create, update, delete: if isAdmin();
      }
      match /subdimensiKokurikuler/{docId} {
        allow read, list: if isSignedIn();
        allow write, create, update, delete: if isAdmin();
      }
      
      match /semester/{semesterId} {
        match /nilaiIntrakurikuler/{docId} {
          allow read, list: if isSignedIn();
          allow write, create, update, delete: if isGuru();
        }
        match /nilaiKokurikuler/{docId} {
          allow read, list: if isSignedIn();
          allow write, create, update, delete: if isGuru();
        }
        match /catatanAnak/{docId} {
          allow read, list: if isSignedIn();
          allow write, create, update, delete: if isGuru();
        }
        match /kehadiran/{docId} {
          allow read, list: if isSignedIn();
          allow write, create, update, delete: if isGuru();
        }
      }
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
